# ========================================
# Apple Music API Configuration
# ========================================

# Apple Music Private Key (PEM format)
#
# Setup Instructions:
# 1. Visit https://developer.apple.com/account/resources/identifiers/list
# 2. Click '+' button in the top right → Select 'Media IDs'
# 3. Enter Description and click 'Continue' → 'Register'
# 4. Visit https://developer.apple.com/account/resources/authkeys/list
# 5. Click '+' button in the top right
# 6. Enter Key Name, check 'Media Services (MusicKit, ShazamKit)'
# 7. Click 'Continue' → 'Register' → 'Download' to download the .p8 file
# 8. Copy the downloaded file contents and paste below
#    (Note: Keep \n as actual newline characters)
#
APPLE_MUSIC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
MIGTAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBHkwdwIBAQQg...your_private_key_here...
-----END PRIVATE KEY-----"

# Apple Music Key ID
#
# Setup Instructions:
# 1. Visit https://developer.apple.com/account/resources/authkeys/list
# 2. Find the Key you created above
# 3. Copy the value from the 'Key ID' column (e.g., AB12CD34EF)
#
APPLE_MUSIC_KEY_ID="AB12CD34EF"

# Apple Music Team ID
#
# Setup Instructions:
# 1. Visit https://developer.apple.com/account
# 2. Check 'Membership details' in the top right of the page
# 3. Copy the 'Team ID' value (e.g., XY98ZW76VU)
#
APPLE_MUSIC_TEAM_KEY="XY98ZW76VU"


# ========================================
# Telegram Bot Configuration
# ========================================

# Telegram Bot Token
#
# Setup Instructions:
# 1. Search for @BotFather on Telegram
# 2. Create a new bot with /newbot command
# 3. Set bot name and username
# 4. Paste the issued token below (format: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz)
#
TELOXIDE_TOKEN="1234567890:ABCdefGHIjklMNOpqrsTUVwxyz-Example123"

# Telegram Chat ID
#
# Setup Instructions:
# 1. Search for @userinfobot on Telegram
# 2. Send a message to the bot
# 3. Copy the 'Id' value and paste below
#
# Alternative method:
# 1. Send a message to your created bot
# 2. Visit https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates in your browser
# 3. Find the number after "chat":{"id":
#
TELEGRAM_CHAT_ID="123456789"
